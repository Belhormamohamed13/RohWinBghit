{
  "name": "rohwinbghit",
  "private": true,
  "version": "1.0.0",
  "description": "RohWinBghit – Algerian BlaBlaCar-like carpooling platform (web + api).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "lint": "npm-run-all -p lint:api lint:web",
    "lint:api": "npm --workspace apps/api run lint",
    "lint:web": "npm --workspace apps/web run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}

