PORT=4000
NODE_ENV=development

# Mongo
MONGODB_URI=mongodb://localhost:27017/rohwinbghit

# Security
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# Cookies (refresh token)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS
CORS_ORIGIN=http://localhost:5173

# Uploads (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Nodemailer)
EMAIL_FROM="RohWinBghit <no-reply@rohwinbghit.dz>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS (mock/provider adapter)
SMS_PROVIDER=mock

